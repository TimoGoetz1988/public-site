---
// To add your photo: place timo-goetz.jpg in src/assets/ and uncomment the Image import below.
// import { Image } from 'astro:assets';
// import photo from '../../assets/timo-goetz.jpg';
const hasPhoto = false; // set to true after adding src/assets/timo-goetz.jpg
---

<section class="min-h-screen flex items-center">
  <div class="mx-auto max-w-5xl px-6 w-full pt-24 pb-20">

    <div class="grid md:grid-cols-2 gap-16 items-center">

      <!-- Left: Text -->
      <div>
        <!-- Overline -->
        <div class="flex items-center gap-4 mb-12">
          <div style="background: var(--text);" class="w-8 h-px shrink-0"></div>
          <p style="color: var(--muted); letter-spacing: 0.12em;" class="text-xs uppercase">
            KI-Beauftragter · DEKRA zertifiziert
          </p>
        </div>

        <!-- H1 -->
        <h1
          style="color: var(--text); line-height: 1.05;"
          class="text-6xl md:text-7xl font-semibold tracking-tight mb-10"
        >
          KI-Beauftragter<br />
          mit Führungs-<br />
          <span style="color: var(--subtle);">erfahrung.</span>
        </h1>

        <!-- Sub -->
        <p
          style="color: var(--muted);"
          class="text-lg leading-relaxed max-w-md mb-12"
        >
          Ich baue Automatisierungen, die funktionieren —
          weil ich die Prozesse dahinter kenne.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap items-center gap-6">
          <a
            href="/projects"
            style="background: var(--text); color: var(--bg);"
            class="inline-flex items-center gap-2 px-6 py-3 text-sm font-medium rounded-sm hover:opacity-80 transition-opacity"
          >
            Projekte ansehen
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>

          <a
            href="/about"
            style="color: var(--muted); border-bottom: 1px solid var(--subtle);"
            class="text-sm pb-0.5 hover:opacity-60 transition-opacity"
          >
            Über mich
          </a>
        </div>

        <!-- Meta row -->
        <div
          style="border-top: 1px solid var(--border); color: var(--subtle);"
          class="flex flex-wrap gap-8 mt-24 pt-8 text-xs"
        >
          {['Python', 'Prompt Engineering', 'MCP', 'n8n', 'Abschluss 1,0'].map(s => (
            <span>{s}</span>
          ))}
        </div>
      </div>

      <!-- Right: Photo (placeholder until timo-goetz.jpg is added) -->
      <div class="hidden md:flex justify-center items-center">
        <!--
          After adding src/assets/timo-goetz.jpg, replace this div with:
          <Image src={photo} alt="Timo Goetz" width={400} height={400}
            class="rounded-full object-cover"
            style="box-shadow: 0 20px 60px rgba(0,0,0,0.12);"
            loading="eager" />
        -->
        <div
          style="width: 320px; height: 320px; border-radius: 50%; background: var(--bg-2); border: 1px solid var(--border);"
          class="flex items-center justify-center"
        >
          <span style="color: var(--subtle);" class="text-xs text-center px-8">
            Foto hinzufügen:<br />src/assets/timo-goetz.jpg
          </span>
        </div>
      </div>

    </div>
  </div>
</section>
