---
---

<section id="case-study" style="border-top: 1px solid var(--border); background: var(--bg-card);">
  <div class="mx-auto max-w-5xl px-6 py-24">

    <!-- Section label -->
    <div class="mb-12 flex items-center gap-3">
      <div class="h-px w-8" style="background: var(--border-2);"></div>
      <span class="text-xs font-medium uppercase tracking-widest" style="color: var(--muted);">Praxis</span>
    </div>

    <!-- Headline -->
    <h2 class="text-3xl font-semibold tracking-tight md:text-4xl" style="color: var(--text);">
      Was passiert, wenn Prognose greift.
    </h2>
    <p class="mt-3 text-base md:text-lg" style="color: var(--muted);">
      Ein anonymisierter DACH-Betreiber mit 500+ Automaten.
    </p>

    <!-- KPI grid -->
    <div class="mt-12 grid gap-6 md:grid-cols-3">

      <div class="rounded-xl px-6 py-6" style="border: 1px solid var(--border); background: var(--bg);">
        <p class="text-3xl font-semibold" style="color: var(--text);">
          −XX% {/* [PLACEHOLDER] Verderb-Reduktion in % eintragen */}
        </p>
        <p class="mt-1 text-xs font-medium uppercase tracking-widest" style="color: var(--subtle);">Verderb</p>
      </div>

      <div class="rounded-xl px-6 py-6" style="border: 1px solid var(--border); background: var(--bg);">
        <p class="text-3xl font-semibold" style="color: var(--text);">
          +YY% {/* [PLACEHOLDER] Prognosegenauigkeit eintragen */}
        </p>
        <p class="mt-1 text-xs font-medium uppercase tracking-widest" style="color: var(--subtle);">Prognosegenauigkeit</p>
      </div>

      <div class="rounded-xl px-6 py-6" style="border: 1px solid var(--border); background: var(--bg);">
        <p class="text-3xl font-semibold" style="color: var(--text);">
          Z Mon. {/* [PLACEHOLDER] Payback-Periode eintragen */}
        </p>
        <p class="mt-1 text-xs font-medium uppercase tracking-widest" style="color: var(--subtle);">ROI erreicht</p>
      </div>

    </div>

    <!-- Expandable mechanic note -->
    <details class="mt-10 rounded-xl" style="border: 1px solid var(--border); background: var(--bg);">
      <summary
        class="cursor-pointer select-none px-6 py-4 text-sm font-medium"
        style="color: var(--muted);"
      >
        Gleiche Mechanik — andere Vertikale
      </summary>
      <div class="px-6 py-5" style="border-top: 1px solid var(--border);">
        <p class="text-sm leading-relaxed" style="color: var(--muted);">
          Das Prognose-Modell ist branchenagnostisch: Bäckereien, Frischetheken,
          Gastronomie und Floristik profitieren von denselben Mechanismen —
          saisonale Muster, Wetterkorrelationen, Abverkaufshistorie.
        </p>
      </div>
    </details>

    <!-- Anonymity note -->
    <p class="mt-6 text-xs" style="color: var(--subtle);">
      Alle Angaben anonymisiert. KPIs werden nach Freigabe durch den Kunden aktualisiert.
      {/* [PLACEHOLDER] De-anonymisierung und echte KPIs nach Kunden-Freigabe eintragen */}
    </p>

  </div>
</section>
