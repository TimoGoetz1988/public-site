---
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const statusColor = (s: string) => s === 'live' ? 'var(--text)' : s === 'dev' ? 'var(--text)' : 'var(--muted)';
const statusBg = (s: string) => s === 'live' ? 'var(--bg)' : s === 'dev' ? 'var(--bg)' : 'var(--bg)';
---

<section id="projects" style="border-top: 1px solid var(--border);">
  <div class="mx-auto max-w-5xl px-6 py-24">

    <div class="mb-12 flex items-center gap-4">
      <div style="background: var(--border-2);" class="h-px w-8 shrink-0"></div>
      <p style="color: var(--muted); letter-spacing: 0.12em;" class="text-xs uppercase font-semibold">Projekte</p>
    </div>

    <h2 style="color: var(--text);" class="text-4xl md:text-5xl font-semibold tracking-tight mb-4">
      Was der Markt braucht &mdash;
    </h2>
    <p style="color: var(--muted);" class="mb-16 text-lg">und wie ich es löse.</p>

    <div class="grid gap-5 md:grid-cols-2">
      {projects.map((project) => (
        <a
          href={`/projects/${project.slug}`}
          style="border: 1px solid var(--border); background: var(--bg-card);"
          class="group block rounded-xl p-7 transition-colors hover:bg-[var(--bg)]"
        >
          <div class="flex items-center justify-between mb-5">
            <span
              style={`color: ${statusColor(project.data.status)}; background: ${statusBg(project.data.status)};`}
              class="rounded border border-[var(--border)] px-2.5 py-1 text-xs font-mono font-medium uppercase"
            >
              {project.data.status}
            </span>
            <svg
              width="14" height="14" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
              style="color: var(--subtle);"
              class="transition-all group-hover:translate-x-1 group-hover:text-[var(--text)]"
            >
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </div>

          <h3 style="color: var(--text);" class="text-lg font-semibold mb-2">
            {project.data.title}
          </h3>

          <p style="color: var(--muted);" class="text-sm leading-relaxed mb-5">
            {project.data.solution}
          </p>

          <div class="flex flex-wrap gap-1.5">
            {project.data.stack.map((tech: string) => (
              <span
                style="color: var(--muted); background: var(--bg); border: 1px solid var(--border);"
                class="rounded px-2 py-1 text-xs font-mono"
              >
                {tech}
              </span>
            ))}
          </div>
        </a>
      ))}
    </div>

    <div class="mt-10">
      <a
        href="/projects"
        style="color: var(--text);"
        class="text-sm hover:underline transition-all inline-flex items-center gap-2"
      >
        Alle Projekte ansehen
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>
