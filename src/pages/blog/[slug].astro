---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const external = post.data.externalUrl;
---

<BaseLayout title={`${post.data.title} — Timo Goetz`} description={post.data.description}>
  <div class="mx-auto max-w-3xl px-6 pt-32 pb-24">
    <a
      href="/blog"
      style="color: var(--subtle);"
      class="inline-flex items-center gap-2 text-xs mb-16 hover:opacity-60 transition-opacity"
    >
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 12H5M12 19l-7-7 7-7"/>
      </svg>
      Alle Artikel
    </a>

    <p style="color: var(--subtle);" class="text-xs uppercase tracking-wide mb-4">
      {post.data.date.toLocaleDateString('de-DE', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      })}
    </p>

    <h1 style="color: var(--text);" class="text-4xl md:text-5xl font-semibold tracking-tight mb-8">
      {post.data.title}
    </h1>

    {external && (
      <div
        style="border: 1px solid var(--border); background: var(--bg-2);"
        class="rounded-sm p-6 mb-12"
      >
        <p style="color: var(--muted);" class="text-sm leading-relaxed mb-4">
          Der vollständige Text dieses Artikels ist extern veröffentlicht (z. B. Blogify).
        </p>
        <a
          href={external}
          target="_blank"
          rel="noopener noreferrer"
          style="background: var(--accent); color: #ffffff;"
          class="inline-flex items-center gap-2 px-6 py-3 text-sm font-medium rounded-sm hover:opacity-90 transition-opacity"
        >
          Zum vollständigen Artikel
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
          </svg>
        </a>
      </div>
    )}

    <div style="color: var(--muted);" class="prose prose-sm max-w-none mb-16">
      <Content />
    </div>

    {post.data.tags && post.data.tags.length > 0 && (
      <div class="flex flex-wrap gap-2">
        {post.data.tags.map((tag) => (
          <span
            style="color: var(--subtle); border: 1px solid var(--border);"
            class="text-xs px-2 py-1 rounded-sm"
          >
            {tag}
          </span>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
