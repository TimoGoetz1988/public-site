
# ────────────────────────────────────────────────────────────
# Public site — Google Forms contact
# ────────────────────────────────────────────────────────────
# Öffentlich (Astro): Google Forms „Senden“-Link (…/viewform) — wird eingebettet
# Empfehlung: Formular in Google WORKSPACE derselben Organisation erstellen
# (timo-goetz-ai / Marken-Account), Antworten → Google Sheets,
# Zugriff nur für Team-Rollen.
PUBLIC_GOOGLE_FORM_URL=

# ────────────────────────────────────────────────────────────
# Supabase — Datenspeicher für N8N ROI Dashboard
# ────────────────────────────────────────────────────────────
# Projekt: https://supabase.com/dashboard/project/<id>/settings/api
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Server-only: Service-Role Key. NIEMALS im Client verwenden.
# Wird von den API-Routes (src/pages/api/v1/**) benutzt, um RLS zu umgehen.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ────────────────────────────────────────────────────────────
# API — Ingest-Authentifizierung
# ────────────────────────────────────────────────────────────
# Shared Secret, mit dem n8n gegen POST /api/v1/executions authentifiziert.
# In n8n als Header setzen: `x-api-key: <wert>`.
# Derselbe Key kann auch für programmatische READ-Zugriffe auf die
# geschützten API-Endpoints verwendet werden.
API_INGEST_KEY=change-me-to-a-long-random-string

# Optional: Erlaubte Origins für CORS der Read-Endpoints (comma-separated, * für alle)
API_ALLOWED_ORIGINS=*

# ────────────────────────────────────────────────────────────
# Dashboard — Zugriffs-Kontrolle (Tailscale + API-Key Fallback)
# ────────────────────────────────────────────────────────────
# Das Dashboard ist ein internes Analytics-Tool. Zugang regelt die
# Netzwerk-Ebene: nur aus vertrauten CIDRs erreichbar, sonst 404.
# Default: Tailscale CGNAT + Loopback.
# Bei Bedarf erweitern, z. B. um ein privates LAN:
#   TRUSTED_CIDRS=100.64.0.0/10,127.0.0.0/8,::1/128,10.0.0.0/8
#
# Reverse-Proxy-Hinweis: Die Middleware liest X-Forwarded-For. Stelle
# sicher, dass nur dein Traefik/Coolify XFF setzen kann (Default bei
# Coolify → safe). Sonst ist der CIDR-Check spoofbar.
TRUSTED_CIDRS=100.64.0.0/10,127.0.0.0/8,::1/128
